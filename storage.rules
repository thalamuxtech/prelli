rules_version = '2';

// PreLLI Storage (Implementation Plan §3.1) — used if the free `prelli` bucket is available.
// Public can read media; only signed-in staff can upload (size/type limited).
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 8 * 1024 * 1024
        && request.resource.contentType.matches('image/.*|video/.*');
    }
  }
}
