rules_version = '2';

// PreLLI Firestore security (Implementation Plan §7) — free plan, client-direct writes.
// Public can READ published content and CREATE form submissions / subscribers
// (guarded by App Check + field validation). Only signed-in staff can manage content.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function role() {
      return isSignedIn()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : "";
    }
    function isEditor() {
      return role() in ["superadmin", "admin", "editor"];
    }
    function isSuperadmin() {
      return role() == "superadmin";
    }
    function isEmail(v) {
      return v is string && v.matches('^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$') && v.size() <= 254;
    }

    // ── Public-readable content, editor-writable ────────────────────────────
    match /posts/{id} {
      allow read: if resource.data.status == "published" || isEditor();
      allow write: if isEditor();
    }
    match /events/{id}       { allow read: if true; allow write: if isEditor(); }
    match /galleries/{id}    { allow read: if true; allow write: if isEditor(); }
    match /team/{id}         { allow read: if true; allow write: if isEditor(); }
    match /sponsors/{id}     { allow read: if true; allow write: if isEditor(); }
    match /testimonials/{id} { allow read: if true; allow write: if isEditor(); }
    match /initiatives/{id}  { allow read: if true; allow write: if isEditor(); }
    match /impactStats/{id}  { allow read: if true; allow write: if isEditor(); }
    match /campaigns/{id}    { allow read: if true; allow write: if isEditor(); }
    match /heroSlides/{id}   { allow read: if true; allow write: if isEditor(); }

    // Site visit stats: public increment (single counter doc), staff read.
    match /siteStats/{id} {
      allow read: if true;
      allow create, update: if true;
    }
    match /settings/{doc} {
      allow read: if true;
      allow write: if isEditor();
    }

    // ── Newsletter subscribers: public create, staff manage ─────────────────
    match /subscribers/{id} {
      allow read, update, delete: if isEditor();
      allow create: if isEmail(request.resource.data.email)
        && request.resource.data.status == "active"
        && request.resource.data.keys().hasOnly(["email", "name", "source", "status", "createdAt"]);
    }

    // ── Contact / volunteer submissions: public create, staff manage ────────
    match /submissions/{id} {
      allow read, update, delete: if isEditor();
      allow create: if request.resource.data.type in ["contact", "volunteer", "partner", "pledge"]
        && isEmail(request.resource.data.email)
        && request.resource.data.name is string
        && request.resource.data.name.size() > 1
        && request.resource.data.name.size() <= 120
        && request.resource.data.message is string
        && request.resource.data.message.size() <= 4000
        && request.resource.data.handled == false;
    }

    // ── Internal: inventory & stock movements (staff only, never public) ─────
    match /inventory/{id}      { allow read, write: if isEditor(); }
    match /stockMovements/{id} { allow read, write: if isEditor(); }

    // ── Staff accounts ──────────────────────────────────────────────────────
    // Only superadmins can see other staff (incl. who the superadmins are).
    // A signed-in user may always read their own record.
    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isSuperadmin());
      // Superadmins manage all staff; a user may clear their own first-login flag.
      allow create, delete: if isSuperadmin();
      allow update: if isSuperadmin()
        || (request.auth.uid == uid
            && request.resource.data.role == resource.data.role
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(["mustChangePassword"]));
    }
  }
}
